# -------------------------------------------------------------------
# MediBot environment variables
# -------------------------------------------------------------------
# Copy this file to `.env` and paste your Gemini API key. Never commit
# your real `.env` file — it is already listed in .gitignore.
#
# Get a free key at: https://aistudio.google.com/app/apikey
#
# No key? That's fine — MediBot runs in offline demo mode automatically.
# -------------------------------------------------------------------

GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the default model (gemini-2.5-flash).
# Other options: gemini-2.5-flash-lite, gemini-flash-lite-latest
# GEMINI_MODEL=gemini-2.5-flash
